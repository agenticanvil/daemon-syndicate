{
  "name": "daemon-syndicate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.7.0",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "generate:sfx": "node scripts/generate-sfx.mjs",
    "lint": "oxlint src --deny-warnings && npm run lint:snapshots && tsc --noEmit && knip",
    "lint:snapshots": "node scripts/check-snapshot-return-types.mjs",
    "test": "vitest run",
    "perf": "node scripts/perf-run.mjs",
    "sim": "node scripts/sim-run.mjs",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "lucide": "^1.24.0",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@types/three": "^0.185.1",
    "knip": "^6.26.0",
    "oxc-parser": "^0.139.0",
    "oxlint": "^1.73.0",
    "playwright": "^1.61.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
